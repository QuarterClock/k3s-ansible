# Cilium BGP Control Plane — apiVersion cilium.io/v2 (Cilium 1.16+).
---
apiVersion: cilium.io/v2
kind: CiliumBGPPeerConfig
metadata:
name: k3s-ansible-bgp-peer
spec:
timers:
connectRetryTimeSeconds: 120
holdTimeSeconds: 90
keepAliveTimeSeconds: 30
ebgpMultihop: 10
gracefulRestart:
enabled: true
restartTimeSeconds: 120
families:
- afi: ipv4
safi: unicast
advertisements:
matchLabels:
k3s-ansible.cilium.io/bgp-advert: "true"
---
apiVersion: cilium.io/v2
kind: CiliumBGPAdvertisement
metadata:
name: k3s-ansible-bgp-advertisements
labels:
k3s-ansible.cilium.io/bgp-advert: "true"
spec:
advertisements:
{% if cilium_exportPodCIDR | default(true) | bool %}
- advertisementType: PodCIDR
{% endif %}
- advertisementType: Service
service:
addresses:
- LoadBalancerIP
selector:
matchExpressions:
- key: somekey
operator: NotIn
values: ['never-used-value']
---
apiVersion: cilium.io/v2
kind: CiliumBGPClusterConfig
metadata:
name: k3s-ansible-bgp-cluster
spec:
nodeSelector:
matchLabels:
kubernetes.io/os: linux
bgpInstances:
- name: k3s-ansible
localASN: {{ cilium_bgp_my_asn | int }}
peers:
{% if _cilium_bgp_neighbors | length > 0 %}
{% for item in _cilium_bgp_neighbors %}
- name: peer-{{ loop.index }}
peerASN: {{ item.peer_asn | int }}
peerAddress: "{{ item.peer_address }}"
peerConfigRef:
name: k3s-ansible-bgp-peer
{% endfor %}
{% else %}
- name: peer-1
peerASN: {{ cilium_bgp_peer_asn | int }}
peerAddress: "{{ cilium_bgp_peer_address }}"
peerConfigRef:
name: k3s-ansible-bgp-peer
{% endif %}
---
apiVersion: cilium.io/v2
kind: CiliumLoadBalancerIPPool
metadata:
name: k3s-ansible-lb-pool
spec:
blocks:
{% if "/" in (cilium_bgp_lb_cidr | string) %}
- cidr: "{{ cilium_bgp_lb_cidr }}"
{% else %}
- start: "{{ cilium_bgp_lb_cidr.split('-')[0] }}"
stop: "{{ cilium_bgp_lb_cidr.split('-')[1] }}"
{% endif %}
